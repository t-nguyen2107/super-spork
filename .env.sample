# ── LM Studio / Ollama LLM (OpenAI-compatible API) ────────────────
OLLAMA_BASE_URL=http://127.0.0.1:1234/v1/
OLLAMA_MODEL=google/gemma-4-e4b

# Embedding model — must match what LM Studio has loaded
EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

# ── PostgreSQL (matches docker-compose.yml) ────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=crm
PG_USER=crm
PG_PASSWORD=crm_local_pw
